# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/scopeflow
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Server Configuration
SERVER_PORT=8080

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-minimum-32-characters-long

# OpenAI Configuration
OPENAI_API_KEY=sk-...

# AWS Configuration
S3_BUCKET=scopeflow-mvp
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Frontend Configuration (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_AUTH_DOMAIN=localhost

# Optional: Spring Profiles
SPRING_PROFILES_ACTIVE=dev
